{
  "name": "weki",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.8.1",
  "engines": {
    "node": ">=20.11",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "node tools/run-root-task.cjs build",
    "ci": "pnpm lint:deps && pnpm build",
    "db:migrate": "pnpm --filter @weki/db db:migrate",
    "db:reset": "pnpm --filter @weki/db db:reset",
    "dev": "turbo run dev",
    "lint:deps": "tsx tools/lint-deps.ts",
    "test": "node tools/run-root-task.cjs test"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "tsx": "^4.19.2",
    "turbo": "^2.5.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
