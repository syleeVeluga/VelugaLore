{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "WekiDocs",
  "version": "0.0.0",
  "identifier": "io.veluga.wekidocs",
  "build": {
    "beforeDevCommand": "pnpm dev:renderer",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "pnpm build:renderer",
    "frontendDist": "../dist/renderer"
  },
  "app": {
    "windows": [
      {
        "title": "WekiDocs",
        "label": "main",
        "width": 1240,
        "height": 820,
        "minWidth": 900,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
