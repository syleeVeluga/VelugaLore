{
  "name": "@weki/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:migrate": "tsx src/commands.ts migrate",
    "db:reset": "tsx src/commands.ts reset",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@weki/core": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}
